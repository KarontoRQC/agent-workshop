FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=1
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5178,http://localhost:5178,http://127.0.0.1:5188,http://localhost:5188

CHAT_PROVIDER=longcat
CHAT_CONFIG_FALLBACK=local
COZE_API_TOKEN=your_coze_api_token
COZE_BOT_ID=7652282276604756003
COZE_ROUTE_PLANNER_BOT_ID=7655970825086074920
COZE_RECOMMENDER_BOT_ID=7652585242385006626
COZE_USER_ID=your_coze_user_id
COZE_CHAT_URL=https://api.coze.cn/v3/chat
COZE_CONNECT_TIMEOUT=10
COZE_READ_TIMEOUT=300

# OpenAI-compatible LongCat provider.
LONGCAT_API_KEY=your_longcat_api_key
LONGCAT_BASE_URL=https://api.longcat.chat/openai/v1
LONGCAT_MODEL=LongCat-2.0-Preview
LONGCAT_MAX_TOKENS=1000

# Optional prompt path overrides.
# ROUTE_PLANNER_PROMPT_PATH=backend/prompts/knowledge_graph_agent.txt
# RECOMMENDER_PROMPT_PATH=backend/prompts/recommended_agent.txt

# Optional: override the recommender candidate set. Leave unset to load data/source_agents_full.json.
# COZE_AGENT_NAMES=帝王竞技场,第一性原理挖掘,①战略专家

TTS_PROVIDER=browser
EDGE_TTS_EXE=edge-tts
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_TIMEOUT=25
